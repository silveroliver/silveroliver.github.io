@prefix cla: <https://data.agriguide.ag/ontologies/agent/> .
@prefix cli: <https://data.agriguide.ag/ontologies/interval/> .
@prefix clid: <https://data.agriguide.ag/ontologies/identifier/> .
@prefix clq: <https://data.agriguide.ag/ontologies/quantity/> .
@prefix clp: <https://data.agriguide.ag/ontologies/product/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .


clp:
    a owl:Ontology ;
    dcterms:title "AgriGuide - Product Domain Model - Formulation Ingredients"@en ;
    dcterms:created "2022-11-14"^^xsd:date ;
    dcterms:modified "2026-03-12"^^xsd:date ;
    dc:publisher "Croplife Europe" ;
    dcterms:description """This Product Ontology encodes the Croplife EU Digital Product Label information model. It is designed to provide a structural backbone which complies with EU Commission Regulation 547/2011, that provides fully structured - and therefore
        machine-readable - data regarding product usage information, and that can be extended by users to encode additional regulatory 
        requirements at a national or territory level. Where possible, references to the relevant legislation are included in the 
        class and property documentation.
    """@en ;
    rdfs:comment "<p><i><b>The following diagram is manually maintained and indicative only (with no guarantee of formal accuracy): please see the schemas and text documentation for the formal specification</b></i></p><img src='./../img/product.png' style='width:100%;margin-top:25px'>"@en ;
    owl:versionInfo "1.1"^^xsd:string ;
    vann:preferredNamespaceUri "https://data.agriguide.ag/ontologies/product/" ;
    vann:preferredNamespacePrefix "clp" ;
    dcterms:rights "(c) Croplife Europe"@en  .


############## Classes ##############

clp:FormulationIngredient
    a owl:Class ;
    skos:prefLabel "FormulationIngredient"@en ;
    skos:definition "An ingredient of the product formulation"@en ;
    rdfs:isDefinedBy clp:
.


clp:Substance
    a owl:Class ;
    skos:prefLabel "Substance"@en ;
    skos:definition "A substance that is used as an ingredient in the product formulation"@en ;
    rdfs:isDefinedBy clp:
.

clp:SubstanceRole
    a owl:Class ;
    skos:prefLabel "SubstanceRole"@en ;
    skos:definition "The role which a substance plays in a formulation"@en ;
    rdfs:isDefinedBy clp:
.


clp:ModeOfAction
    a owl:Class ;
    skos:prefLabel "ModeOfAction"@en ;
    skos:definition "The XRAC mode of action of the formulation"@en ;
    rdfs:isDefinedBy clp:
.


clp:ModeOfActionScheme
    a owl:Class ;
    skos:prefLabel "ModeOfActionScheme"@en ;
    skos:definition ""@en ;
    rdfs:isDefinedBy clp:
.


clp:ChemicalClass
    a owl:Class ;
    skos:prefLabel "ChemicalClass"@en ;
    skos:definition "The XRAC chemical class of a substance"@en ;
    rdfs:isDefinedBy clp:
.

clp:ChemicalClass
    a owl:Class ;
    skos:prefLabel "DangerousIngredientsHazardStatement"@en ;
    skos:definition ""@en ;
    rdfs:isDefinedBy clp:
.


clp:CoformulantsQbaStatement
    a owl:Class ;
    skos:prefLabel "CoformulantsQbaStatement"@en ;
    skos:definition ""@en ;
    rdfs:isDefinedBy clp:
.



############## Object Properties ##############



clp:formulationIngredients
    a owl:ObjectProperty ;
    rdfs:domain clp:RegisteredFormulation ;
    rdfs:range clp:FormulationIngredient ;
    skos:prefLabel "formulationIngredients"@en ;
    rdfs:definition "The active substances, synergists and safeners which are included in the product"@en ;
    rdfs:isDefinedBy clp:
.

clp:substance
    a owl:ObjectProperty ;
    rdfs:domain clp:FormulationIngredient ;
    rdfs:range clp:Substance ;
    skos:prefLabel "substance"@en ;
    rdfs:definition "A substance that is used as an ingredient in the product formulation. As per EU Directive No 547/2011 Annex 1 section 1c ' The name must be as given in the list contained in Annex VI to Regulation (EC) No 1272/2008 of the European Parliament and of the Council (2) or, if not included therein, its ISO common name. If the latter is not available, the active substance shall be designated by its chemical designation according to IUPAC rules'"@en ;
    rdfs:isDefinedBy clp:
.

clp:substanceRole
    a owl:ObjectProperty ;
    rdfs:domain clp:FormulationIngredient ;
    rdfs:range clp:SubstanceRole ;
    skos:prefLabel "substanceRole"@en ;
    rdfs:definition "The role performed by the substance in the formulation (e.g. active substance, synergist, safener) - todo: review for controlled vocab"@en ;
    rdfs:isDefinedBy clp:
.

clp:concentration
    a owl:ObjectProperty ;
    rdfs:domain clp:FormulationIngredient ;
    rdfs:range clp:Concentration ;
    skos:prefLabel "concentration"@en ;
    rdfs:definition "The concentration of an ingredient used in the product formulation"@en ;
    rdfs:isDefinedBy clp:
.

clp:chemicalClass
    a owl:ObjectProperty ;
    rdfs:domain clp:Substance ;
    rdfs:range clp:ChemicalClass ;
    skos:prefLabel "chemicalClass"@en ;
    rdfs:definition "The XRAC chemical class of the substance"@en ;
    rdfs:isDefinedBy clp:
.

clp:modeOfAction
    a owl:ObjectProperty ;
    rdfs:domain clp:Substance ;
    rdfs:range clp:ModeOfAction ;
    skos:prefLabel "modeOfAction"@en ;
    rdfs:definition "The XRAC mode of action classification for the substance"@en ;
    rdfs:isDefinedBy clp:
.


clp:modeOfActionScheme
    a owl:ObjectProperty ;
    rdfs:domain clp:ModeOfAction ;
    rdfs:range clp:ModeOfActionScheme ;
    skos:prefLabel "modeOfActionScheme"@en ;
    rdfs:definition "The encoding scheme to which the XRAC code belongs, i.e. current or legacy classifications"@en ;
    rdfs:isDefinedBy clp:
.


clp:dangerousIngredientsWarning
    a owl:ObjectProperty ;
    rdfs:domain clp:RegisteredFormulation ;
    rdfs:range clp:DangerousIngredientsHazardStatement ;
    skos:prefLabel "dangerousIngredientsWarning"@en ;
    rdfs:definition ""@en ;
    rdfs:isDefinedBy clp:
.


clp:territory
    a owl:ObjectProperty ;
    rdfs:domain clp:CoformulantsQbaStatement ;
    rdfs:range clp:Country ;
    skos:prefLabel "territory"@en ;
    rdfs:definition "The country within which the statement applies"@en ;
    rdfs:isDefinedBy clp:
.

############## Data Properties ##############


clp:statement
    a owl:DatatypeProperty ;
    rdfs:domain clp:DangerousIngredientsHazardStatement ;
    rdfs:range clp:rdf:langString ;
    skos:prefLabel "statement"@en ;
    rdfs:definition ""@en ;
    rdfs:isDefinedBy clp:
.

clp:isPure
    a owl:DatatypeProperty ;
    rdfs:domain clp:FormulationIngredient ;
    rdfs:range clp:xsd:boolean ;
    skos:prefLabel "isPure"@en ;
    rdfs:definition "Flags whether the ingredient is of a high purity grade"@en ;
    rdfs:isDefinedBy clp:
.


clp:casRegistryNo
    a owl:DatatypeProperty ;
    rdfs:domain clp:Substance ;
    rdfs:range clp:xsd:string ;
    skos:prefLabel "casRegistryNo"@en ;
    rdfs:definition "The CAS Registry number of the substance, to be used where an EINECS number is not available - see Annex VI to Regulation (EC) No 1272/2008"@en ;
    rdfs:isDefinedBy clp:
.



clp:ecNo
    a owl:DatatypeProperty ;
    rdfs:domain clp:Substance ;
    rdfs:range clp:xsd:string ;
    skos:prefLabel "ecNo"@en ;
    rdfs:definition "The EC number of the substance, to be used wherever possible - see Annex VI to Regulation (EC) No 1272/2008"@en ;
    rdfs:isDefinedBy clp:
.

clp:einecsNo
    a owl:DatatypeProperty ;
    rdfs:domain clp:Substance ;
    rdfs:range clp:xsd:string ;
    skos:prefLabel "einecsNo"@en ;
    rdfs:definition "The EC number of a commercial substance - see Annex VI to Regulation (EC) No 1272/2008"@en ;
    rdfs:isDefinedBy clp:
.

clp:elincsNo
    a owl:DatatypeProperty ;
    rdfs:domain clp:Substance ;
    rdfs:range clp:xsd:string ;
    skos:prefLabel "elincsNo"@en ;
    rdfs:definition "The EC number of a notifiable substance - see Annex VI to Regulation (EC) No 1272/2008"@en ;
    rdfs:isDefinedBy clp:
.

clp:nlpNo
    a owl:DatatypeProperty ;
    rdfs:domain clp:Substance ;
    rdfs:range clp:xsd:string ;
    skos:prefLabel "nlpNo"@en ;
    rdfs:definition "The EC number of no-longer-polymer substances - see Annex VI to Regulation (EC) No 1272/2008"@en ;
    rdfs:isDefinedBy clp:
.

clp:synonym
    a owl:DatatypeProperty ;
    rdfs:domain clp:Substance ;
    rdfs:range clp:rdf:langString ;
    skos:prefLabel "synonym"@en ;
    rdfs:definition ""@en ;
    rdfs:isDefinedBy clp:
.

clp:echaId
    a owl:DatatypeProperty ;
    rdfs:domain clp:Substance ;
    rdfs:range clp:xsd:string ;
    skos:prefLabel "echaId"@en ;
    rdfs:definition "ECHA ID"@en ;
    rdfs:isDefinedBy clp:
.

clp:isoCommonName
    a owl:DatatypeProperty ;
    rdfs:domain clp:Substance ;
    rdfs:range clp:rdf:langString ;
    skos:prefLabel "isoCommonName"@en ;
    rdfs:definition "The ISO Common Name of the substance"@en ;
    rdfs:isDefinedBy clp:
.

clp:iupacChemicalDesignation
    a owl:DatatypeProperty ;
    rdfs:domain clp:Substance ;
    rdfs:range clp:rdf:langString ;
    skos:prefLabel "iupacChemicalDesignation"@en ;
    rdfs:definition "The IUPAC name of the substance"@en ;
    rdfs:isDefinedBy clp:
.


clp:description
    a owl:DatatypeProperty ;
    rdfs:domain clp:SubstanceRole ;
    rdfs:range clp:rdf:langString ;
    skos:prefLabel "description"@en ;
    rdfs:definition ""@en ;
    rdfs:isDefinedBy clp:
.


############## Interface Classes ##############


clp:RegisteredFormulation
    a owl:Class ;
    skos:prefLabel "RegisteredFormulation"@en ;
    skos:definition "A crop protection product formulation that has been registered in a country or region"@en ;
    rdfs:isDefinedBy clp:
.


clp:Concentration
    a owl:Class ;
    rdfs:subClassOf clp:Quantity ;
    skos:prefLabel "Concentration"@en ;
    skos:definition "An interface class assigned via range inference which maps to an explicitly defined Concentration from the Quantity ontology."@en ;
    rdfs:isDefinedBy clp:
.


